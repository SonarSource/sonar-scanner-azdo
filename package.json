{
  "name": "sonar-scanner-vsts",
  "version": "0.0.2-SNAPSHOT",
  "repository": "SonarSource/sonar-scanner-vsts",
  "license": "LGPL-3.0",
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "^1.11.0",
    "@types/fs-extra": "9.0.13",
    "@types/jest": "29.5.8",
    "@types/jest-when": "2.7.3",
    "@types/node": "^22.13.10",
    "@types/node-fetch": "^2.6.9",
    "@types/semver": "7.5.8",
    "@types/tmp": "0.2.1",
    "@types/yargs": "13.0.2",
    "@typescript-eslint/parser": "5.59.11",
    "axios": "^1.6.0",
    "dateformat": "3.0.3",
    "del": "3.0.0",
    "es5-ext": "0.10.64",
    "eslint": "8.48.0",
    "eslint-plugin-import": "2.28.1",
    "eslint-plugin-promise": "6.1.1",
    "event-stream": "4.0.1",
    "fast-check": "^3.22.0",
    "fs-extra": "10.0.0",
    "globby": "11.0.4",
    "gulp": "^5.0.1",
    "gulp-artifactory-upload": "1.4.0",
    "gulp-collect": "^0.1.0",
    "gulp-decompress": "2.0.2",
    "gulp-download": "0.0.1",
    "gulp-exec": "5.0.0",
    "gulp-json-editor": "2.5.6",
    "gulp-rename": "2.0.0",
    "gulp-replace": "1.1.4",
    "gulp-typescript": "5.0.1",
    "gulp-util": "^1.0.0",
    "jest": "29.7.0",
    "jest-when": "3.5.2",
    "map-stream": "^0.1.0",
    "merge-stream": "2.0.0",
    "needle": "3.2.0",
    "node-fetch": "2.7.0",
    "openpgp": "^5.11.3",
    "prettier": "3.0.3",
    "semver": "^7.6.0",
    "sonarqube-scanner": "3.3.0",
    "stream": "^0.0.2",
    "tfx-cli": "^0.23.1",
    "through2": "^4.0.2",
    "tmp": "0.2.1",
    "ts-jest": "29.1.1",
    "typescript": "^5.8.2",
    "vinyl": "^2.2.1",
    "yargs": "17.7.0"
  },
  "scripts": {
    "build": "gulp build",
    "clean": "gulp clean",
    "deploy": "gulp deploy",
    "promote": "gulp promote",
    "burgr": "gulp burgr:sonarcloud && gulp burgr:sonarqube",
    "sonarqube": "gulp sonarqube-analysis:sonarqube && gulp sonarqube-analysis:sonarcloud",
    "format": "prettier --write --list-different \"{commonv5,common,extensions}/**/*.{js,ts}\"",
    "format-check": "prettier --list-different \"{commonv5,common,extensions}/**/*.{js,ts}\"",
    "lint": "eslint --ext js,ts --quiet \"{commonv5,common,extensions}/**/*.{js,ts}\"",
    "lint-report": "eslint --ext js,ts -f json -o eslint-report.json \"{commonv5,common,extensions}/**/*.{js,ts}\"",
    "test-build": "gulp build:test",
    "test": "jest",
    "test-ci": "jest --coverage",
    "ts-check": "tsc --noEmit",
    "validate": "npm run lint && npm run ts-check && npm run format-check && npm run test",
    "validate-ci": "npm run lint-report && npm run ts-check && npm run format-check && npm run test-ci",
    "cyclonedx-run": "cyclonedx-npm --package-lock-only --output-file",
    "cyclonedx": "gulp cycloneDx"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=8"
  },
  "jest": {
    "clearMocks": true,
    "collectCoverageFrom": [
      "common/**/*.ts",
      "commonv5/**/*.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "lcovonly",
      "text"
    ],
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/node_modules",
      "<rootDir>/config",
      "<rootDir>/build"
    ],
    "testRegex": "(/__tests__/.*|\\-test)\\.ts$",
    "testEnvironmentOptions": {
      "url": "http://localhost/"
    },
    "transform": {
      ".(ts)$": "ts-jest"
    }
  },
  "dependencies": {
    "azure-devops-node-api": "15.1.2",
    "azure-pipelines-task-lib": "^5.2.8"
  },
  "overrides": {
    "event-stream": "4.0.1",
    "azure-pipelines-task-lib": {
      "nodejs-file-downloader": {
        "follow-redirects": "1.15.6"
      }
    }
  }
}
