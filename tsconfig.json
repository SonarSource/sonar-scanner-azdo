{
  "compilerOptions": {
    /* Basic Options */
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "types": ["jest", "node"],
    "moduleResolution": "node",
    "rootDir": "./",
    "baseUrl": "."
  },
  "include": [
    "./common/ts/**/*.ts",
    "./commonv5/ts/**/*.ts",
    "./extensions/**/*.ts"
  ]
}